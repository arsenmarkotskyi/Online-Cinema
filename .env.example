# Copy to ".env" and fill in secrets. Pydantic reads ".env" from the project root.

# --- Stripe (test mode: keys from https://dashboard.stripe.com/test/apikeys) ---
# Secret key: Developers → API keys → Secret key (starts with sk_test_... or sk_live_...)
# Use a real value from the Stripe Dashboard; do not copy example placeholders into production.
STRIPE_SECRET_KEY=

# After running: stripe listen --forward-to localhost:8000/webhooks/stripe
# paste the "whsec_..." signing secret from the CLI output
STRIPE_WEBHOOK_SECRET=

# Where Stripe redirects the browser after pay / cancel (any http(s) URL; app appends session_id for success if needed)
STRIPE_SUCCESS_URL=http://127.0.0.1:8000/docs
STRIPE_CANCEL_URL=http://127.0.0.1:8000/docs

# ISO code, lowercase in API (usd, eur, uah, ...)
STRIPE_CURRENCY=usd

# --- Celery (token cleanup + future email) ---
# Local: docker compose up -d redis
# Full stack (API + worker + beat + Redis + MinIO + Mailpit): docker compose up --build
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- MinIO (optional; docker-compose sets these for the api service) ---
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadminsecret
# MINIO_BUCKET=online-cinema

# Base URL for links in emails (activation, docs link in reset email)
PUBLIC_BASE_URL=http://127.0.0.1:8000

# OpenAPI/Swagger UI; set false in production
ENABLE_OPENAPI_DOCS=true
# If true, /docs, /redoc, /openapi.json require Authorization: Bearer (active user JWT)
OPENAPI_DOCS_REQUIRE_AUTH=false

# --- SMTP ---
# If SMTP_HOST is empty, outbound email is skipped (worker logs only).

# Option A — Local "as in prod" (same code path; letters stay on your machine):
#   docker compose up -d redis mailpit
#   Then:
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_USE_TLS=false
# SMTP_FROM=noreply@example.test
# SMTP_USER=
# SMTP_PASSWORD=
# Open http://127.0.0.1:8025 to read captured mail.

# Option B — Real provider (Brevo, SendGrid, Mailgun, Amazon SES, corporate SMTP):
# Create SMTP credentials in the provider dashboard; set verified sender for SMTP_FROM.
# Example (Brevo): SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_USE_TLS=true
# Example (SendGrid): SMTP_HOST=smtp.sendgrid.com  SMTP_USER=apikey  SMTP_PASSWORD=<your API key>
# Production API URL for links inside emails:
# PUBLIC_BASE_URL=https://your-api.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
